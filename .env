# API Configuration
# For local development, point to your backend server
# EXPO_PUBLIC_API_URL=http://localhost:5000

# For Android emulator, use this instead:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# For physical device on same network, use your machine IP:
 EXPO_PUBLIC_API_URL=http://192.168.29.213:5050


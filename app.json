{
  "expo": {
    "name": "Jio Fiinserv",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tanishaappdev.jiofinserv"
    },
    "android": {
      "package": "com.tanishaappdev.jiofinserv",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a128c658-ea4f-4bcb-8993-ea0ca7099e9c"
      }
    },
    "owner": "tanisha.appdev"
  }
}
